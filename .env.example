# SendGrid — only credentials needed (Mixpanel is handled via MCP)
# Steps to get API key:
#   SendGrid → Settings → API Keys → Create API Key (Mail Send permission)
# SENDGRID_SENDER must be a verified sender in SendGrid (Settings → Sender Authentication)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_SENDER=reports@yourdomain.com

# Report recipients — comma-separated, no spaces around commas
REPORT_RECIPIENTS=recipient@hungama.com

# Gmail SMTP — only credentials needed (Mixpanel is handled via MCP)
# Steps to get App Password:
#   Google Account → Security → 2-Step Verification → App passwords → Create
GMAIL_SENDER=your-address@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Report recipients — comma-separated, no spaces around commas
REPORT_RECIPIENTS=recipient@hungama.com
